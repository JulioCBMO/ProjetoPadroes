@startuml
skinparam dpi 100
skinparam linetype ortho
left to right direction
skinparam classAttributeIconSize 0
skinparam classFontStyle bold
skinparam packageStyle rectangle



package "Command" {
    class SistemaEvento {
        - String nomeEvento
        - boolean abertoParaSubmissoes
        - LocalDate dataLimite
        + start()
        + isAberto()
        + isDentroDoPrazo()
        + setDataLimite(LocalDate)
        + getDataLimite()
    }
    interface Command {
        + executar()
    }
    class StartCommand {
        - SistemaEvento sistema
        + executar()
    }
    class PainelControle {
        - Command slot
        + setCommand(Command)
        + pressionarBotao()
    }
}

' ==================== FACTORY METHOD ====================
package "FactoryMethod" {
    abstract class Usuario {
        # String email
        # String senha
        # String instituicao
        + getEmail()
        + getInstituicao()
        + abstract getTipo()
    }
    class Pesquisador {
        - List<Artigo> artigosSubmetidos
        - boolean isRevisor
        - List<String> especialidades
        - List<Artigo> artigosParaRevisar
        + submeterArtigo(Artigo)
        + aceitarConviteRevisao()
        + isRevisor()
        + adicionarEspecialidade(String)
        + getEspecialidades()
        + adicionarArtigoParaRevisar(Artigo)
        + getArtigosParaRevisar()
        + getTipo()
    }
    class Chair {
        + getTipo()
    }
    interface UsuarioFactory {
        + criar(String, String, String): Usuario
    }
    class PesquisadorFactory implements UsuarioFactory
    class ChairFactory implements UsuarioFactory
    class UsuarioFactoryRegistry {
        + criar(String, String, String, String): Usuario
    }
    class AreaTematica {
        - static Set<String> areasCadastradas
        + static cadastrarArea(String)
        + static areaExiste(String): boolean
        + static getAreasCadastradas(): Set<String>
        + static limparAreas()
    }
}

' ==================== STATE ARTIGO ====================
package "StateArtigo" {
    class Artigo {
        - int id
        - String titulo
        - String resumo
        - Pesquisador autorPrincipal
        - List<Pesquisador> coautores
        - List<String> pareceres
        - List<ArtigoObserver> observers
        - List<String> temas
        - Set<String> selos
        - List<Pesquisador> revisoresDesignados
        - Map<String, Veredito> vereditos
        - EstadoArtigo estadoAtual
        + submeter()
        + distribuir()
        + concluirRevisao(boolean)
        + setEstado(EstadoArtigo)
        + getStatus()
        + isAutorOuCoautor(Pesquisador): boolean
        + adicionarCoautor(Pesquisador)
        + adicionarTema(String)
        + getTemas()
        + adicionarParecer(String)
        + getPareceres()
        + adicionarSelo(String)
        + getSelos()
        + anexarObserver(ArtigoObserver)
        + removerObserver(ArtigoObserver)
        + adicionarRevisorDesignado(Pesquisador)
        + getRevisoresDesignados()
        + adicionarVeredito(String, Veredito)
        + getVereditos()
        + todosRevisoresAvaliaram(): boolean
    }
    interface EstadoArtigo {
        + submeter(Artigo)
        + distribuir(Artigo)
        + concluirRevisao(Artigo, boolean)
        + getStatus()
    }
    class EstadoSubmetido implements EstadoArtigo
    class EstadoEmRevisao implements EstadoArtigo
    class EstadoAceito implements EstadoArtigo
    class EstadoRejeitado implements EstadoArtigo
}

' ==================== STATE CONVITE ====================
package "StateConvite" {
    class ComiteTecnico {
        - List<Convite> convites
        + convidar(Pesquisador): Convite
        + getRevisoresAtivos(): List<Pesquisador>
    }
    class Convite {
        - Pesquisador pesquisador
        - EstadoConvite estado
        + aceitar(List<String>)
        + recusar()
        + setEstado(EstadoConvite)
        + getPesquisador()
        + getStatus()
    }
    interface EstadoConvite {
        + aceitar(Convite, List<String>)
        + recusar(Convite)
        + getDescricao()
    }
    class ConvitePendente implements EstadoConvite
    class ConviteAceito implements EstadoConvite
    class ConviteRecusado implements EstadoConvite
}

' ==================== STRATEGY ====================
package "Strategy" {
    interface CompatibilidadeStrategy {
        + calcular(Artigo, Pesquisador): double
    }
    class CompatibilidadeExata implements CompatibilidadeStrategy
    class CompatibilidadePonderada implements CompatibilidadeStrategy
    class DistribuidorDeArtigos {
        - CompatibilidadeStrategy strategy
        + DistribuidorDeArtigos(CompatibilidadeStrategy)
        + setStrategy(CompatibilidadeStrategy)
        + distribuir(List<Artigo>, List<Pesquisador>): Map<Pesquisador, List<Artigo>>
        - escolherRevisor(Artigo, List<Pesquisador>): Pesquisador
    }

    interface EstrategiaConsolidacao {
        + consolidar(List<Veredito>): Veredito
    }
    class ConsolidacaoHierarquica implements EstrategiaConsolidacao
    class ConsolidacaoOtimista implements EstrategiaConsolidacao
}

' ==================== OBSERVER ====================
package "Observer" {
    interface ArtigoObserver {
        + onEstadoAlterado(Artigo)
    }
    class NotificadorEmail implements ArtigoObserver {
        - EmailService emailService
        + onEstadoAlterado(Artigo)
    }
    class LogAuditoria implements ArtigoObserver {
        + onEstadoAlterado(Artigo)
    }
}

' ==================== TEMPLATE METHOD ====================
package "TemplateMethod" {
    abstract class RelatorioRevisaoTemplate {
        + gerarRelatorio(Artigo)
        - imprimirCabecalho()
        # abstract imprimirCorpo(Artigo)
        - imprimirRodape()
    }
    class RelatorioDetalhado extends RelatorioRevisaoTemplate {
        # imprimirCorpo(Artigo)
    }
    class RelatorioSimples extends RelatorioRevisaoTemplate {
        # imprimirCorpo(Artigo)
    }
}

' ==================== FACADE DASHBOARD ====================
package "FacadeDashboard" {
    class DashboardFacade {
        - List<Artigo> todosArtigos
        - List<Pesquisador> todosPesquisadores
        + gerarResumo(): DashboardDTO
        - montarPendencias(): List<PendenciaDTO>
    }
    class DashboardDTO {
        - int totalArtigos
        - int totalRevisores
        - int artigosAvaliados
        - int artigosPendentes
        - List<PendenciaDTO> pendencias
        - List<String> artigosAceitosComSelos
        + imprimir()
    }
    class PendenciaDTO {
        + String artigoTitulo
        + String revisorEmail
    }
}

' ==================== DECORATOR ====================
package "Decorator" {
    interface ArtigoExibivel {
        + exibir(): String
    }
    class ArtigoBase implements ArtigoExibivel {
        - Artigo artigo
        + exibir()
    }
    abstract class SeloDecorator implements ArtigoExibivel {
        # ArtigoExibivel artigoDecorado
        + exibir()
    }
    class SeloMelhorArtigo extends SeloDecorator {
        + exibir()
    }
    class SeloMencaoHonrosa extends SeloDecorator {
        + exibir()
    }
    class FabricaExibicao {
        + static montarExibicao(Artigo): ArtigoExibivel
    }
}

' ==================== NOTIFICAÇÃO ====================
package "Notificacao" {
    class EmailService {
        - String remetente
        - String senha
        + enviar(String, String, String)
    }
    abstract class EmailNotificacao {
        # Artigo artigo
        # EmailService emailService
        + enviar()
        # abstract montarAssunto(): String
        # abstract montarCorpo(): String
        # formatarPareceres(): String
    }
    class EmailAceitacao extends EmailNotificacao {
        + montarAssunto()
        + montarCorpo()
    }
    class EmailRejeicao extends EmailNotificacao {
        + montarAssunto()
        + montarCorpo()
    }
}

' ==================== UTIL ====================
package "Util" {
    enum Veredito {
        REJEITADO(0, false)
        FRACAMENTE_REJEITADO(1, false)
        FRACAMENTE_ACEITO(2, true)
        ACEITO(3, true)
        + getPeso()
        + isAprovado()
        + fromString(String): Veredito
        + toString()
    }
    class DataLoaderCSV {
        + static carregarUsuarios(String): List<Usuario>
    }
}

' ==================== MAIN ====================
package "Main" {
    class Main {
        - static SistemaEvento evento
        - static Chair coordenador
        - static List<Pesquisador> pesquisadores
        - static ComiteTecnico comite
        - static List<Artigo> listaArtigos
        - static EmailService emailService
        - static boolean distribuido
        - static int proximoIdArtigo
        - static LocalDate dataLimiteEvento
        - static EstrategiaConsolidacao estrategiaConsolidacao
        + main(String[])
        - static rf01InicializarEvento(Scanner)
        - static rf02ListarUsuarios()
        - static rf03CadastrarAreas(Scanner)
        - static rf04ConvidarRevisor(Scanner)
        - static rf05SubmeterArtigo(Scanner)
        - static rf06DistribuirArtigos()
        - static rf07ConcluirRevisao(Scanner)
        - static rf08Dashboard()
        - static rf09NotificarAutores()
        - static rf10AplicarSelo(Scanner)
        - static rf11EscolherEstrategia(Scanner)
        - static carregarCSV()
        - static exibirBoasVindas()
        - static exibirMenu()
        - static separador(String)
        - static lerInt(Scanner): int
    }
}

' ==================== RELACIONAMENTOS ====================

' Command
SistemaEvento --> StartCommand : instancia
StartCommand ..|> Command
PainelControle --> Command : usa

' FactoryMethod
Usuario <|-- Pesquisador
Usuario <|-- Chair
UsuarioFactory <|.. PesquisadorFactory
UsuarioFactory <|.. ChairFactory
UsuarioFactoryRegistry ..> UsuarioFactory : usa
PesquisadorFactory ..> Pesquisador : cria
ChairFactory ..> Chair : cria
AreaTematica --> Artigo : valida temas

' State Artigo
Artigo *--> EstadoArtigo : state
EstadoSubmetido ..|> EstadoArtigo
EstadoEmRevisao ..|> EstadoArtigo
EstadoAceito ..|> EstadoArtigo
EstadoRejeitado ..|> EstadoArtigo
Artigo --> Pesquisador : autor
Artigo --> Pesquisador : coautores

' State Convite
ComiteTecnico *--> Convite
Convite *--> EstadoConvite
ConvitePendente ..|> EstadoConvite
ConviteAceito ..|> EstadoConvite
ConviteRecusado ..|> EstadoConvite
Convite --> Pesquisador

' Strategy (Distribuição)
DistribuidorDeArtigos --> CompatibilidadeStrategy : usa
CompatibilidadeExata ..|> CompatibilidadeStrategy
CompatibilidadePonderada ..|> CompatibilidadeStrategy
DistribuidorDeArtigos ..> Artigo : distribui
DistribuidorDeArtigos ..> Pesquisador : escolhe

' Strategy (Consolidação)
Main --> EstrategiaConsolidacao : usa
ConsolidacaoHierarquica ..|> EstrategiaConsolidacao
ConsolidacaoOtimista ..|> EstrategiaConsolidacao
EstrategiaConsolidacao ..> Veredito : consolida

' Observer
Artigo o--> ArtigoObserver : notifica
NotificadorEmail ..|> ArtigoObserver
LogAuditoria ..|> ArtigoObserver
NotificadorEmail --> EmailService

' Template Method (Relatórios)
RelatorioRevisaoTemplate <|-- RelatorioDetalhado
RelatorioRevisaoTemplate <|-- RelatorioSimples
RelatorioRevisaoTemplate ..> Artigo : gera

' Facade
DashboardFacade --> Artigo : consulta
DashboardFacade --> Pesquisador : consulta
DashboardFacade ..> DashboardDTO : cria
DashboardDTO *--> PendenciaDTO

' Decorator
ArtigoBase ..|> ArtigoExibivel
SeloDecorator ..|> ArtigoExibivel
SeloMelhorArtigo --|> SeloDecorator
SeloMencaoHonrosa --|> SeloDecorator
FabricaExibicao ..> ArtigoExibivel : monta
ArtigoExibivel ..> Artigo : exibe

' Notificação (Template Method e Observer)
EmailNotificacao <|-- EmailAceitacao
EmailNotificacao <|-- EmailRejeicao
EmailNotificacao --> Artigo
EmailNotificacao --> EmailService
NotificadorEmail ..> EmailNotificacao : cria

' Util
DataLoaderCSV ..> UsuarioFactoryRegistry : usa
DataLoaderCSV ..> Usuario : carrega
Veredito --> Artigo : usado em vereditos

' Main orquestra tudo
Main --> SistemaEvento
Main --> Chair
Main --> Pesquisador
Main --> ComiteTecnico
Main --> Artigo
Main --> EmailService
Main --> DistribuidorDeArtigos
Main --> EstrategiaConsolidacao
Main --> DashboardFacade
Main --> FabricaExibicao
Main --> DataLoaderCSV

@enduml
